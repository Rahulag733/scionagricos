# ScionAgricos - Environment Variables
# Copy this file to .env and fill in your values

# AWS RDS PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@RDS_HOST:5432/DATABASE_NAME
# Example: postgresql://scionadmin:MyPassword123@scionagricos.abc123.us-east-1.rds.amazonaws.com:5432/sciondb
DATABASE_URL=postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/your_database
